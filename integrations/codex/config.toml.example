# qmemd MCP server for the OpenAI Codex CLI.
# Paste this block into ~/.codex/config.toml, or run:
#   codex mcp add qmemd -- qmemd mcp
# Requires `qmemd` on PATH (npm i -g @ciel2142/qmemd).
# npx fallback: command = "npx", args = ["-y", "@ciel2142/qmemd", "mcp"]
[mcp_servers.qmemd]
command = "qmemd"
args = ["mcp"]

# Optional — Claude-style memory hooks (auto session snapshot + beacon).
# Enable Codex's experimental hooks engine, then drop hooks/hooks.json at
# ~/.codex/hooks.json. Needs a recent Codex CLI (hooks shipped v0.114.0+).
[features]
codex_hooks = true
