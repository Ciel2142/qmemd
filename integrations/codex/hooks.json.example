{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          { "type": "command", "command": "qmemd recall --session", "statusMessage": "Loading qmemd memory", "timeout": 15 }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "qmemd hook beacon", "timeout": 10 }
        ]
      }
    ]
  }
}
